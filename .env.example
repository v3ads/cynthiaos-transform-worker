# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002
SERVICE_NAME=cynthiaos-transform-worker
NODE_ENV=development

# ── Database (Neon Postgres) ──────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Batch control ─────────────────────────────────────────────────────────────
BATCH_SIZE=100
REPLAY=false
